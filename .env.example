# OpenSandbox 连接配置（BFF 用，不入库）
# 本地开发：起一个 OpenSandbox server（uvx opensandbox-server），默认 localhost:8080
OSB_DOMAIN=localhost:8080
OSB_PROTOCOL=http
OSB_API_KEY=changeme

# BFF 监听端口
BFF_PORT=8787

# 控制面 SQLite 数据文件路径（相对 apps/bff 目录）
BFF_DB_PATH=./data/control.sqlite

# Mock 模式：=1 时 lifecycle 路由返回内存假数据，无需真实 OpenSandbox 即可验证前端。
# 起了真实 OpenSandbox 后置空或删掉此行。
BFF_MOCK=1
