{
  "name": "agentsandbox",
  "version": "0.2.0",
  "private": true,
  "description": "面向 AI Agent 的沙箱管理控制台 — 基于 OpenSandbox 运行时",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "dev:web": "pnpm --filter @agentsandbox/web dev",
    "dev:bff": "pnpm --filter @agentsandbox/bff dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=20"
  }
}
